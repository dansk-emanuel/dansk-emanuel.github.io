        const cardInner = document.getElementById('cardInner');
        const cardTrigger = document.getElementById('cardTrigger');
        const danishText = document.getElementById('danishText');
        const translatedText = document.getElementById('translatedText');
        const controls = document.getElementById('controls');
        const cardCountDisplay = document.getElementById('cardCount');
        const statusLabel = document.getElementById('statusLabel');
        const gameUI = document.getElementById('gameUI');
        const finishUI = document.getElementById('finishUI');
        const btnRight = document.getElementById('btnRight');
        const btnWrong = document.getElementById('btnWrong');
        const btnRestart = document.getElementById('btnRestart');

        // Init App
        function init() {
            shuffle(deck);
            currentCardIndex = 0;
            isFlipped = false;
            isTransitioning = false;
            showCard();
            updateUI();
        }

        function shuffle(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
        }

        function showCard() {
            const card = deck[currentCardIndex];
            danishText.innerText = card.da;
            translatedText.innerText = card[currentLanguage];
        }

        function updateUI() {
            cardCountDisplay.innerText = `Kort tilbage: ${deck.length}`;
            if (deck.length === 0) {
                gameUI.classList.add('hidden');
                finishUI.classList.remove('hidden');
            } else {
                gameUI.classList.remove('hidden');
                finishUI.classList.add('hidden');
            }
        }

        // Card Flip Event
        cardTrigger.addEventListener('click', () => {
            if (isTransitioning || isFlipped) return;
            
            isFlipped = true;
            cardInner.classList.add('is-flipped');
            controls.classList.remove('opacity-0', 'pointer-events-none');
            statusLabel.innerText = "Hvad synes du?";
        });

        // Handlers for Right/Wrong
        function handleAnswer(isCorrect) {
            if (isTransitioning) return;
            isTransitioning = true;

            // 1. Skjul knapper
            controls.classList.add('opacity-0', 'pointer-events-none');

            // 2. Vend kortet tilbage til forsiden
            cardInner.classList.remove('is-flipped');
            isFlipped = false;
            statusLabel.innerText = "Opdaterer...";

            // 3. Vent 400ms før teksten skiftes
            setTimeout(() => {
                if (isCorrect) {
                    deck.splice(currentCardIndex, 1);
                } else {
                    // Flyt til bunden af bunken eller bare næste index
                    currentCardIndex = (currentCardIndex + 1) % deck.length;
                }

                if (deck.length > 0) {
                    // Sørg for at index ikke er out of bounds hvis vi fjernede det sidste element
                    if (currentCardIndex >= deck.length) currentCardIndex = 0;
                    showCard();
                    statusLabel.innerText = "Klik på kortet for at se svar";
                }

                updateUI();
                isTransitioning = false;
            }, 400);
        }

        btnRight.addEventListener('click', (e) => {
            e.stopPropagation();
            handleAnswer(true);
        });

        btnWrong.addEventListener('click', (e) => {
            e.stopPropagation();
            handleAnswer(false);
        });

        btnRestart.addEventListener('click', () => {
            deck = [...flashcardsData];
            init();
        });

        langSelect.addEventListener('change', (e) => {
            currentLanguage = e.target.value;
            if (deck.length > 0) showCard();
        });

        // Start app
        window.onload = init;
    </script>
</body>
</html>
