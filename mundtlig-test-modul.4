<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dansk Flashcards - Lær Dansk</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .perspective-1000 {
            perspective: 1000px;
        }
        .flip-card-inner {
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }
        .flip-card-inner.is-flipped {
            transform: rotateY(180deg);
        }
        .flip-card-front, .flip-card-back {
            position: absolute;
            width: 100%;
            height: 100%;
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        .flip-card-back {
            transform: rotateY(180deg);
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col font-sans">

    <!-- Header & Sprogvalg -->
    <header class="bg-white shadow-sm p-4 sticky top-0 z-10">
        <div class="max-w-2xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
            <h1 class="text-xl font-bold text-gray-800">Dansk Flashcards</h1>
            <div class="flex items-center gap-2 w-full sm:w-auto">
                <label for="langSelect" class="text-sm font-medium text-gray-600">Målsprog:</label>
                <select id="langSelect" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                    <option value="english">Engelsk</option>
                    <option value="bengali">Bengali</option>
                    <option value="hindi">Hindi</option>
                    <option value="urdu">Urdu</option>
                    <option value="ukrainian">Ukrainsk</option>
                    <option value="russian">Russisk</option>
                    <option value="persian">Persisk</option>
                    <option value="turkish">Tyrkisk</option>
                    <option value="kurmanji">Kurdisk Kurmanji</option>
                    <option value="sorani">Kurdisk Sorani</option>
                    <option value="nepali">Nepalesisk</option>
                    <option value="swahili">Kiswahili</option>
                    <option value="french">Fransk</option>
                    <option value="twi">Twi</option>
                    <option value="bosnian">Bosnisk</option>
                    <option value="somali">Somali</option>
                    <option value="serbian">Serbisk</option>
                    <option value="tigrinya">Tigrinya</option>
                    <option value="mandarin">Mandarin Kinesisk</option>
                </select>
            </div>
        </div>
    </header>

    <main class="flex-grow flex flex-col items-center justify-center p-6" id="app">
        <!-- Status -->
        <div id="gameUI" class="w-full max-w-md flex flex-col items-center gap-6">
            <div class="w-full flex justify-between items-center text-gray-600 font-semibold px-2">
                <span id="cardCount">Kort tilbage: 0</span>
                <span id="statusLabel" class="text-xs uppercase tracking-wider bg-gray-200 px-2 py-1 rounded">Klik på kortet for at se svar</span>
            </div>

            <!-- Flashcard Container -->
            <div id="cardTrigger" class="w-full h-80 perspective-1000 cursor-pointer">
                <div id="cardInner" class="flip-card-inner relative w-full h-full">
                    <!-- Forside (Dansk) -->
                    <div class="flip-card-front bg-white text-black border-2 border-gray-200 text-center">
                        <p id="danishText" class="text-2xl font-medium"></p>
                    </div>
                    <!-- Bagside (Målsprog) -->
                    <div class="flip-card-back bg-[#F5F5DC] text-black text-center">
                        <p id="translatedText" class="text-2xl font-medium"></p>
                    </div>
                </div>
            </div>

            <!-- Knapper (Vises kun når kortet er vendt) -->
            <div id="controls" class="flex gap-4 w-full opacity-0 transition-opacity duration-300 pointer-events-none">
                <button id="btnWrong" class="flex-1 bg-red-500 hover:bg-red-600 text-white font-bold py-4 rounded-xl shadow-lg transition-transform active:scale-95">
                    Forkert
                </button>
                <button id="btnRight" class="flex-1 bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-xl shadow-lg transition-transform active:scale-95">
                    Rigtigt
                </button>
            </div>
        </div>

        <!-- Færdig Skærm -->
        <div id="finishUI" class="hidden flex flex-col items-center justify-center text-center gap-6">
            <div class="text-6xl">🎉</div>
            <h2 class="text-3xl font-bold text-gray-800">Du er færdig!</h2>
            <p class="text-gray-600">Du har lært alle sætningerne i denne runde.</p>
            <button id="btnRestart" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-full shadow-lg transition-transform active:scale-95">
                Start forfra
            </button>
        </div>
    </main>

