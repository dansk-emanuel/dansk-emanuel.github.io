            "Kiswahili": ["Jina lake la kwanza ni nani?", "Jina lake la ukoo ni nani?", "Siku yake ya kuzaliwa ni lini?", "Anatoka wapi?", "Anaishi wapi?", "Namba yake ya simu ni ipi?", "Barua pepe yake ni ipi?", "Jina lake la kwanza ni ____.", "Jina lake la ukoo ni ____.", "Siku yake ya kuzaliwa ni ____________.", "Anatoka _______.", "Anaishi _______.", "Namba yake ya simu ni __________.", "Barua pepe yake ni ________."],
            "Fransk": ["Quel est son prénom ?", "Quel est son nom de famille ?", "C'est quand son anniversaire ?", "D'où vient-elle/il ?", "Où habite-elle/il ?", "Quel est son numéro de téléphone ?", "Quel est son e-mail ?", "Son prénom est ____.", "Son nom de famille est ____.", "Son anniversaire est le ____________.", "Elle/il vient de _______.", "Elle/il habite à _______.", "Son numéro de téléphone est __________.", "Son e-mail est ________."],
            "Twi": ["Ne din de bɛn?", "Ne nananom din de bɛn?", "Bere bɛn na wɔwoo no?", "Ofiri he?", "Ɔte he?", "Ne tɛlɛfɔn nɔma de bɛn?", "Ne e-mail de bɛn?", "Ne din de ____.", "Ne nananom din de ____.", "Wɔwoo no ____________.", "Ofiri _______.", "Ɔte _______.", "Ne tɛlɛfɔn nɔma de __________.", "Ne e-mail de ________."],
            "Bosnisk": ["Kako se ona/on zove (ime)?", "Kako se ona/on preziva?", "Kada joj/mu je rođendan?", "Odakle je ona/on?", "Gdje ona/on živi?", "Koji je njen/njegov broj telefona?", "Koji je njen/njegov e-mail?", "Njeno/njegovo ime je ____.", "Njeno/njegovo prezime je ____.", "Njen/njegov rođendan je ____________.", "Ona/on dolazi iz _______.", "Ona/on živi u _______.", "Njen/njegov broj telefona je __________.", "Njen/njegov e-mail je ________."],
            "Somali": ["Magaciisa/Magaceeda koowaad waa maxay?", "Naanaystiisa/Naanaysteeda waa maxay?", "Goormuu/Goormay dhashay?", "Xagee buu/bay ka yimid?", "Xagee buu/bay degan yahay?", "Waa maxay lambarkiisa/lambarkeeda telefoonka?", "Waa maxay iimaylkiisa/iimaylkiisu?", "Magaciisa/Magaceeda koowaad waa ____.", "Naanaystiisa/Naanaysteeda waa ____.", "Dhalashadiisu/Dhalashadeedu waa ____________.", "Wuxuu/Waxay ka yimid _______.", "Wuxuu/Waxay degan yahay _______.", "Lambarkiisa/Lambarkeeda telefoonka waa __________.", "Iimaylkiisa/Iimaylkiisu waa ________."],
            "Serbisk": ["Kako se ona/on zove (ime)?", "Kako se ona/on preziva?", "Kada joj/mu je rođendan?", "Odakle je ona/on?", "Gde ona/on živi?", "Koji je njen/njegov broj telefona?", "Koji je njen/njegov e-mail?", "Njeno/njegovo ime je ____.", "Njeno/njegovo prezime je ____.", "Njen/njegov rođendan je ____________.", "Ona/on dolazi iz _______.", "Ona/on živi u _______.", "Njen/njegov broj telefona je __________.", "Njen/njegov e-mail je ________."],
            "Tigrinya": ["ሽሙ/ሽማ መን እዩ?", "መጸውዒ ስሙ/ስማ መን እዩ?", "ልደቱ/ልደታ መዓስ እዩ?", "ካበይ መጺኡ/መጺኣ?", "ኣበይ ይነብር/ትነብር?", "ቁጽሪ ተለፎኑ/ተለፎና ክንደይ እዩ?", "ኢመይሉ/ኢመይላ እንታይ እዩ?", "ሽሙ/ሽማ ____ እዩ/እያ።", "መጸውዒ ስሙ/ስማ ____ እዩ/እያ።", "ልደቱ/ልደታ ብ ____________ እዩ።", "ካብ _______ መጺኡ/መጺኣ።", "ኣብ _______ ይነብር/ትነብር።", "ቁጽሪ ተለፎኑ/ተለፎና __________ እዩ/እያ።", "ኢመይሉ/ኢመይላ ________ እዩ/እያ።"],
            "Mandarin Kinesisk": ["她/他的名字是什么？", "她/他的姓是什么？", "她/他的生日是什么时候？", "她/他来自哪里？", "她/他住在哪里？", "她/他的电话号码是多少？", "她/他的电子邮件是什么？", "她/他的名字是 ____。", "她/他的姓是 ____。", "她/他的生日是 ____________。", "她/他来自 _______。", "她/他住在 _______。", "她/他的电话号码是 __________。", "她/他的电子邮件是 ________。"],
            "Tadjikisk": ["Номи ӯ чист?", "Насаби ӯ чист?", "Зодрӯзи ӯ кай аст?", "Ӯ аз куҷост?", "Ӯ дар куҷо зиндагӣ мекунад?", "Рақами телефони ӯ чанд аст?", "Почтаи электронии ӯ чист?", "Номи ӯ ____ аст.", "Насаби ӯ ____ аст.", "Зодрӯзи ӯ ____________ аст.", "Ӯ аз _______ аст.", "Ӯ дар _______ зиндагӣ мекунад.", "Рақами телефони ӯ __________ аст.", "Почтаи электронии ӯ ________ аст."]
        };

        const danishPhrases = [
            "Hvad er hendes/hans fornavn?",
            "Hvad er hendes/hans efternavn?",
            "Hvornår har hun/han fødselsdag?",
            "Hvor kommer hun/han fra?",
            "Hvor bor hun/han?",
            "Hvad er hendes/hans telefonnummer?",
            "Hvad er hendes/hans e-mail?",
            "Hendes/hans fornavn er ____.",
            "Hendes/hans efternavn er ____.",
            "Hun/han har fødselsdag den ____________.",
            "Hun/han kommer fra _______.",
            "Hun/han bor i _______.",
            "Hans/hendes telefonnummer er __________.",
            "Hans/hendes e-mail er ________."
        ];

        // Tilstand
        let currentDeck = [];
        let currentCardIndex = 0;
        let isFlipped = false;
        let isTransitioning = false;
        let selectedLang = "Engelsk";

        // Elementer
        const langSelect = document.getElementById('languageSelect');
        const cardInner = document.getElementById('card-inner');
        const cardTrigger = document.getElementById('card-trigger');
        const danishText = document.getElementById('danish-text');
        const targetText = document.getElementById('target-text');
        const controls = document.getElementById('controls');
        const cardsLeftEl = document.getElementById('cards-left');
        const gameContainer = document.getElementById('game-container');
        const finishScreen = document.getElementById('finish-screen');
        const rightBtn = document.getElementById('right-btn');
        const wrongBtn = document.getElementById('wrong-btn');
        const restartBtn = document.getElementById('restart-btn');
        const resetBtn = document.getElementById('reset-btn');

        // Initialisering
        function init() {
            // Fyld sprogvælger
            Object.keys(translations).forEach(lang => {
                const opt = document.createElement('option');
                opt.value = lang;
                opt.textContent = lang;
                langSelect.appendChild(opt);
            });

            startNewGame();
        }

        function startNewGame() {
            selectedLang = langSelect.value;
            // Opret bunke med objekter {da, target}
            currentDeck = danishPhrases.map((phrase, index) => ({
                da: phrase,
                target: translations[selectedLang][index]
            }));
            // Shuffle
            currentDeck.sort(() => Math.random() - 0.5);
            
            currentCardIndex = 0;
            isFlipped = false;
            isTransitioning = false;
            
            gameContainer.classList.remove('hidden');
            finishScreen.classList.add('hidden');
            updateCard();
        }

        function updateCard() {
            if (currentDeck.length === 0) {
                showFinishScreen();
                return;
            }
            
            // Sikr os at vi er inden for rækkevidde
            if (currentCardIndex >= currentDeck.length) currentCardIndex = 0;
            
            const card = currentDeck[currentCardIndex];
            danishText.textContent = card.da;
            targetText.textContent = card.target;
            cardsLeftEl.textContent = currentDeck.length;
            
            // Reset visuel tilstand
            cardInner.classList.remove('flipped');
            controls.classList.add('opacity-0');
            controls.style.pointerEvents = 'none';
            isFlipped = false;
        }

        function showFinishScreen() {
            gameContainer.classList.add('hidden');
            finishScreen.classList.remove('hidden');
        }

        // Event Listeners
        cardTrigger.addEventListener('click', () => {
            if (isTransitioning || isFlipped) return;
            
            isFlipped = true;
            cardInner.classList.add('flipped');
            
            // Vis knapper efter animation er næsten færdig
            setTimeout(() => {
                controls.classList.remove('opacity-0');
                controls.style.pointerEvents = 'auto';
            }, 300);
        });

        function handleAnswer(isCorrect) {
            if (isTransitioning) return;
            isTransitioning = true;

            // 1. Vend tilbage til forsiden
            cardInner.classList.remove('flipped');
            controls.classList.add('opacity-0');
            controls.style.pointerEvents = 'none';

            setTimeout(() => {
                // 2. Opdater logikken bag kulissen
                if (isCorrect) {
                    currentDeck.splice(currentCardIndex, 1);
                    // Hvis vi slettede det sidste element, hop til start
                    if (currentCardIndex >= currentDeck.length) currentCardIndex = 0;
                } else {
                    // Gå til næste kort i bunken
                    currentCardIndex = (currentCardIndex + 1) % currentDeck.length;
                }

                // 3. Opdater tekst og gør klar
                updateCard();
                isTransitioning = false;
            }, 400); // 400ms timing som requested
        }

        rightBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            handleAnswer(true);
        });

        wrongBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            handleAnswer(false);
        });

        langSelect.addEventListener('change', startNewGame);
        restartBtn.addEventListener('click', startNewGame);
        resetBtn.addEventListener('click', startNewGame);

        // Start appen
        init();
    </script>
</body>
</html>
