<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sprog Flashcards</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .perspective-1000 {
            perspective: 1000px;
        }
        .flip-card-inner {
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }
        .flipped {
            transform: rotateY(180deg);
        }
        .flip-card-front, .flip-card-back {
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }
        .flip-card-back {
            transform: rotateY(180deg);
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col items-center p-4 font-sans text-gray-900">

    <div id="app" class="w-full max-w-2xl">
        <!-- Header & Sprogvalg -->
        <div class="mb-8 text-center">
            <h1 class="text-3xl font-bold mb-4">Sprog Flashcards</h1>
            <div class="bg-white p-4 rounded-xl shadow-sm inline-block w-full">
                <label for="languageSelect" class="block text-sm font-medium text-gray-700 mb-2">Vælg målsprog:</label>
                <select id="languageSelect" class="w-full p-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none bg-white">
                    <!-- Options genereres af JS -->
                </select>
            </div>
        </div>

        <!-- Status & Kort -->
        <div id="game-container">
            <div class="flex justify-between items-center mb-4 px-2">
                <span class="text-sm font-semibold bg-white px-3 py-1 rounded-full shadow-sm">
                    Kort tilbage: <span id="cards-left">0</span>
                </span>
                <button id="reset-btn" class="text-sm text-blue-600 hover:underline">Start forfra</button>
            </div>

            <!-- Flashcard -->
            <div class="perspective-1000 w-full h-80 cursor-pointer" id="card-trigger">
                <div id="card-inner" class="flip-card-inner relative w-full h-full shadow-xl rounded-2xl">
                    <!-- Forside (Dansk) -->
                    <div class="flip-card-front absolute inset-0 bg-white rounded-2xl flex items-center justify-center p-8 text-center border border-gray-200">
                        <p id="danish-text" class="text-2xl md:text-3xl font-medium"></p>
                    </div>
                    <!-- Bagside (Målsprog) -->
                    <div class="flip-card-back absolute inset-0 bg-[#F5F5DC] rounded-2xl flex items-center justify-center p-8 text-center border border-gray-200 text-black">
                        <p id="target-text" class="text-2xl md:text-3xl font-medium"></p>
                    </div>
                </div>
            </div>

            <!-- Kontrolknapper -->
            <div id="controls" class="mt-8 flex gap-4 justify-center opacity-0 transition-opacity duration-300">
                <button id="wrong-btn" class="bg-red-500 hover:bg-red-600 text-white px-8 py-3 rounded-xl font-bold shadow-lg transform active:scale-95 transition-all">
                    Forkert
                </button>
                <button id="right-btn" class="bg-green-500 hover:bg-green-600 text-white px-8 py-3 rounded-xl font-bold shadow-lg transform active:scale-95 transition-all">
                    Rigtigt
                </button>
            </div>
        </div>

        <!-- Færdig Skærm -->
        <div id="finish-screen" class="hidden text-center py-12 bg-white rounded-2xl shadow-xl">
            <div class="text-5xl mb-4">🎉</div>
            <h2 class="text-3xl font-bold mb-2">Færdig!</h2>
            <p class="text-gray-600 mb-8">Du har lært alle ordene i denne runde.</p>
            <button id="restart-btn" class="bg-blue-600 text-white px-10 py-4 rounded-2xl font-bold hover:bg-blue-700 transition-colors">
                Prøv igen
            </button>
        </div>
    </div>

